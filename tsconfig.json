{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "baseUrl": ".",
    "paths": {
      "@worktreeos/core": ["packages/core/src/index.ts"],
      "@worktreeos/core/*": ["packages/core/src/*.ts"],
      "@worktreeos/compose": ["packages/compose/src/index.ts"],
      "@worktreeos/compose/*": ["packages/compose/src/*.ts"],
      "@worktreeos/daemon": ["packages/daemon/src/index.ts"],
      "@worktreeos/daemon/*": ["packages/daemon/src/*.ts"],
      "@worktreeos/plugin-claude/*": ["packages/plugin-claude/*.ts"],
      "@worktreeos/plugin-opencode": ["packages/plugin-opencode/src/index.ts"],
      "@worktreeos/plugin-opencode/*": ["packages/plugin-opencode/src/*.ts"],
      "@worktreeos/plugin-pi": ["packages/plugin-pi/src/index.ts"],
      "@worktreeos/plugin-pi/*": ["packages/plugin-pi/src/*.ts"],
      "@worktreeos/runtime": ["packages/runtime/src/index.ts"],
      "@worktreeos/runtime/*": ["packages/runtime/src/*.ts"],
      "@worktreeos/ui": ["packages/ui/src/index.ts"],
      "@worktreeos/ui/*": ["packages/ui/src/*.ts"],
      "@/*": ["apps/web/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts"
  ],
  "exclude": [
    "apps/docs"
  ]
}
